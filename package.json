{
  "name": "eurekai",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n srv,web -c blue,green \"tsx watch server.ts\" \"vite\"",
    "dev:server": "tsx watch server.ts",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@mistralai/mistralai": "^1.14.0",
    "alpinejs": "^3.15.8",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.3.0",
    "lucide": "^0.575.0",
    "marked": "^17.0.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-handlebars": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
